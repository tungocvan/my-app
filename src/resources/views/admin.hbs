<h1>ADMIN PAGE</h1>
<input type="file" name="name"  onchange="fileupload(this)"/>
<div id="preview"></div>
<script>
    
        function fileupload(input){
            console.log('fileupload():',input.files[0]);
            var dirDes = "uploads/"; 
            const data = input.files[0];            
            let reader = new FileReader();    
            reader.onload = function() {
                var newData  = {
                    'lastModified'     : data.lastModified,
                    'lastModifiedDate' : data.lastModifiedDate,
                    'name'             : data.name,
                    'tmp_name'         : reader.result,
                    'size'             : data.size,
                    'type'             : data.type,
                    'des'              : dirDes
                };
                var preview = document.querySelector('#preview');      
                var image = new Image();
                image.height = 50;
                image.title = data.name;
                image.src = reader.result;
                preview.appendChild(image);
                (async () => {
                    const rawResponse = await fetch('/admin/upload', {
                        method: 'POST',
                        headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(newData)
                    });
                    const content = await rawResponse.json();
                    fileName = content.data;
                    console.log('content:',fileName);    
                        
                })();
            }
            reader.onerror = function() {
                console.log('error:',reader.error);
            };
            if (data) reader.readAsDataURL(data);
        }    
 
</script>